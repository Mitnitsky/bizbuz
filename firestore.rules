rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User docs: users can only read/write their own
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Family docs and subcollections
    match /families/{familyId} {
      // Any authenticated user can read (needed for invite-code lookup)
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Update: user must be a member after the write (covers join + normal edits)
      allow update: if request.auth != null &&
        request.auth.uid in request.resource.data.member_uids;

      // All family subcollections: only current members
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.member_uids;
      }
    }

    // DLQ: allow Cloud Functions (admin SDK bypasses rules)
    match /ingestion_errors/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
